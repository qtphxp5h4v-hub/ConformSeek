{
  "name": "conformseek",
  "version": "2.0.0",
  "description": "pH-Dependent Protein Conformational Analysis",
  "author": "Calvin",
  "license": "MIT",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",

    "electron:dev": "concurrently \"BROWSER=none npm start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:dev:win": "concurrently \"set BROWSER=none && npm start\" \"wait-on http://localhost:3000 && electron .\"",

    "electron:build": "npm run build && electron-builder",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:linux": "npm run build && electron-builder --linux",

    "pyinstaller": "pyinstaller --onefile --name conformseek_api --collect-all propka --collect-all Bio --collect-all zeep --collect-all lxml conformseek_server.py",
    "pyinstaller:clean": "rm -rf build/ dist/ *.spec"
  },
  "build": {
    "extends": null,
    "appId": "com.calvin.conformseek",
    "productName": "ConformSeek",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "build/**/*",
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "./python-dist",
        "to": ".",
        "filter": [
          "conformseek_api",
          "conformseek_api.exe"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "category": "public.app-category.education",
      "icon": "assets/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "dmg": {
      "title": "ConformSeek ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Science",
      "icon": "assets/icons"
    }
  },
  "dependencies": {
    "d3": "^7.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      "last 1 electron version"
    ],
    "development": [
      "last 1 electron version"
    ]
  }
}
